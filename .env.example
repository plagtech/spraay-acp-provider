# Spraay ACP Provider — Environment Variables
# Copy to .env and fill in your values

# GAME SDK API Key (get from https://console.game.virtuals.io/)
GAME_API_KEY=apt-your-key-here

# Spraay Gateway
GATEWAY_URL=https://gateway.spraay.app

# Agent run interval in seconds (default: 60)
AGENT_INTERVAL=60
